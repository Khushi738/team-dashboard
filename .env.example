DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_postgres_password_here
DB_NAME=team_dashboard
JWT_SECRET=change-this-to-any-long-random-string
PORT=5000

# Optional: your deployed frontend URL (for CORS)
FRONTEND_URL=https://your-app.onrender.com
